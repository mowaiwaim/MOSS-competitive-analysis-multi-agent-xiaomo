REACT_REPORT_ENABLED=1
REACT_AGENT_PROVIDER=deepseek
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_TYPE=enabled
DEEPSEEK_DIRECT_THINKING_MODE=1
DEEPSEEK_API_KEY=your-deepseek-api-key

# Optional fallback or auxiliary model provider.
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_ENDPOINT_ID=your-doubao-endpoint-id
DOUBAO_MODEL_NAME=Doubao-Seed-2.0-lite

# Online search and alert feeds.
VOLC_SEARCH_API_KEY=your-volc-search-api-key
VOLC_SEARCH_BASE_URL=https://open.feedcoopapi.com
VOLC_SEARCH_COUNT=6
VOLC_SEARCH_TIME_RANGE=OneYear
GOOGLE_ALERTS_RSS_URL=your-google-alerts-rss-url

# Optional Feishu questionnaire publishing.
FEISHU_CLI_PATH=
FEISHU_IDENTITY=user
FEISHU_DEFAULT_FOLDER_TOKEN=

FLASK_SECRET_KEY=change-this-for-deployment
